# Chain Configuration
NEXT_PUBLIC_CHAIN_ID=nibiru-testnet-1
NEXT_PUBLIC_RPC_ENDPOINT=https://rpc.testnet.nibiru.fi
NEXT_PUBLIC_REST_ENDPOINT=https://lcd.testnet.nibiru.fi

# Contract Addresses (update after deployment)
NEXT_PUBLIC_CW721_ADDRESS=
NEXT_PUBLIC_MARKETPLACE_ADDRESS=
NEXT_PUBLIC_FACTORY_ADDRESS=

# WalletConnect (optional)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# IPFS Configuration
NEXT_PUBLIC_PINATA_API_KEY=
NEXT_PUBLIC_PINATA_SECRET_KEY=

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Mock mode: no real wallet/contracts (prompt for address, use backend mock service)
NEXT_PUBLIC_USE_MOCK_CONTRACTS=true
NEXT_PUBLIC_MARKETPLACE_ADDRESS=mock_marketplace
NEXT_PUBLIC_FACTORY_ADDRESS=mock_factory
NEXT_PUBLIC_CHAIN_ID=testing
