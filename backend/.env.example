# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nibiru_nft?schema=public"

# Redis (for caching)
REDIS_URL="redis://localhost:6379"

# Nibiru Chain
RPC_ENDPOINT="https://rpc.testnet.nibiru.fi"
REST_ENDPOINT="https://lcd.testnet.nibiru.fi"
CHAIN_ID="nibiru-testnet-1"

# Contract Addresses
MARKETPLACE_CONTRACT=""
FACTORY_CONTRACT=""

# Indexer
ENABLE_INDEXER=true

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# IPFS (Pinata)
PINATA_API_KEY=""
PINATA_SECRET_KEY=""
PINATA_JWT=""

# Optional: NFT.Storage
NFT_STORAGE_API_KEY=""
