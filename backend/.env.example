# Server
PORT=3001
BASE_URL="http://localhost:3001"
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nibiru_nft?schema=public"

# Mock vs real contracts (one-line switch)
USE_MOCK_CONTRACTS=true

# Nibiru Chain (when USE_MOCK_CONTRACTS=false)
RPC_ENDPOINT="https://rpc.testnet.nibiru.fi"
REST_ENDPOINT="https://lcd.testnet.nibiru.fi"
CHAIN_ID="nibiru-testnet-1"
MARKETPLACE_CONTRACT=""
FACTORY_CONTRACT=""

# Indexer (ignored when USE_MOCK_CONTRACTS=true)
ENABLE_INDEXER=false

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Upload: local by default; set IPFS_ENABLED=true for Pinata
IPFS_ENABLED=false
PINATA_API_KEY=""
PINATA_SECRET_KEY=""
